# Copy this file to `.env` and put real keys only in `.env`.
# Never put real API keys in `.env.example`; this file is safe to commit.

NCBI_EMAIL=your.email@example.org
NCBI_API_KEY=
GROBID_URL=http://127.0.0.1:8070

# Backend API
BACKEND_API_KEY=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
CHAT_DEBUG_TIMINGS=false
RAG_PIPELINE=reranked
ALLOW_RETRIEVAL_OVERRIDES=false

# ChromaDB
CHROMA_MODE=cloud
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_HOST=api.trychroma.com
CHROMA_PORT=8000
CHROMA_SSL=true
CHROMA_COLLECTION=dog_behavior_papers
CHROMA_PERSIST_PATH=data/chroma
ANONYMIZED_TELEMETRY=false

# Embeddings
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-001
# Separate key for embedding calls, useful for cost tracking.
GOOGLE_API_KEY_EMBED=
EMBEDDING_NORMALIZE=true
EMBEDDING_SHOW_PROGRESS=true
GOOGLE_API_KEY=
OPENAI_EMBEDDING_BASE_URL=
OPENAI_EMBEDDING_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Retrieval and optional reranking
RETRIEVE_TOP_K=20
CONTEXT_TOP_N=8
RERANKER_PROVIDER=jina
JINA_RERANKER_API_KEY=
JINA_RERANKER_URL=https://api.jina.ai/v1/rerank
JINA_RERANKER_MODEL=jina-reranker-v3

# Answer generation and evaluation
# Final evaluation recommendation:
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-5.6-terra
#LLM_PROVIDER=gemini
#LLM_MODEL_NAME=gemini-2.0-flash
# Separate key for LLM/chat calls, useful for cost tracking.
GOOGLE_API_KEY_LLM=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1500
